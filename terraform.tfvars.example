pm_api_url          = "https://192.168.x.x:8006/api2/json"
pm_api_token_id     = "user@pam!token-name"
pm_api_token_secret = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
github_username     = "your-github-username"

lxc_containers = {
  webserver  = { cores = 2, memory = 2048 }
  database   = { cores = 2, memory = 4096, disk_size = "32G" }
  monitoring = {}
  pihole     = { memory = 256, disk_size = "4G", prevent_destroy = true }
}